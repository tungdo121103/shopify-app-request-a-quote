# Copy this file to `.env` for local development.
# Never place real credentials in `.env.example`.

# -----------------------------------------------------------------------------
# Shopify app
# Shopify CLI normally supplies the required values during `shopify app dev`.
# Set them explicitly for standalone development, tests, or production hosting.
# -----------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.example.com
SCOPES=

# Optional development store used by /auth/login when no `shop` is provided.
SHOPIFY_DEV_STORE=your-development-store.myshopify.com

# Optional custom shop domain accepted during authentication.
SHOP_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# Database
# Local development defaults to prisma/dev.sqlite when DATABASE_URL is empty.
# Configure a persistent production database before deploying multiple instances.
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Email delivery
# Local development: EMAIL_PROVIDER=smtp with Docker MailHog.
# Production: EMAIL_PROVIDER=ses. SendGrid remains an optional fallback.
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@request-a-quote.local
EMAIL_FROM_NAME=Request a Quote
EMAIL_REPLY_TO=

# SMTP / MailHog development settings
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# AWS SES production settings. Prefer an IAM role in hosted environments.
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional SendGrid fallback
SENDGRID_API_KEY=

# Set false only when a separate worker exclusively processes the email queue.
QUOTE_EMAIL_SEND_IMMEDIATELY=true

# -----------------------------------------------------------------------------
# Quote portal and scheduled jobs
# Use separate, cryptographically random values in staging and production.
# The scheduler sends QUOTE_JOB_SECRET in the `x-quote-job-secret` header.
# -----------------------------------------------------------------------------
QUOTE_PORTAL_SECRET=
QUOTE_JOB_SECRET=
